# Copy this file to .env and fill in your values
# .env is gitignored — never commit real secrets

# ──────────────────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string
# Get this from your Neon dashboard → Connection Details → Connection String
# Format: postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST.neon.tech/neondb?sslmode=require

SECRET_KEY=change-me-to-a-random-string

# Set to 1 only in local development — never in production
FLASK_DEBUG=0

# Comma-separated list of allowed origins for CORS (frontend URL)
CORS_ORIGINS=http://localhost:5173
